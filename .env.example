# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---- server-only (NO VITE_ prefix; never commit real values) ----
# Neon Postgres connection string. Use the dev branch while building.
# Read by drizzle.config.ts and the backend; never shipped to the browser.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# ---- client/browser (VITE_ prefix = bundled into the frontend; publishable only) ----
# Neon Auth base URL (used by src/auth.ts in a later phase).
VITE_NEON_AUTH_URL="https://your-project.neon.tech/auth"
